{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    ":automergeMinor",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":semanticCommits",
    ":timezone(America/Los_Angeles)",
    "github>jfroy/flatops//.renovate/autoMerge.json5",
    "github>jfroy/flatops//.renovate/changelogs.json5",
    "github>jfroy/flatops//.renovate/customManagers.json5",
    "github>jfroy/flatops//.renovate/grafanaDashboards.json5",
    "github>jfroy/flatops//.renovate/groups.json5",
    "github>jfroy/flatops//.renovate/labels.json5",
    "github>jfroy/flatops//.renovate/packageRules.json5",
    "github>jfroy/flatops//.renovate/semanticCommits.json5",
    "github>jfroy/flatops//.renovate/talosFactory.json5",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  gitIgnoredAuthors: ["29139614+renovate[bot]@users.noreply.github.com"],
  rebaseWhen: "conflicted",
  hostRules: [
    {
      matchHost: "registry.kantai.xyz",
      enabled: false
    },
    {
      matchHost: "tif.etincelle.cloud",
      enabled: false
    }
  ],
  flux: {
    managerFilePatterns: [
      "/^kubernetes/.+\\.yaml$/",
    ],
  },
  "helm-values": {
    managerFilePatterns: [
      "/^kubernetes/.+\\.yaml$/",
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      "/^kubernetes/.+\\.yaml$/",
    ],
  },
}
