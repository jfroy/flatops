{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/home-operations/plex"],
      versioning: "loose"
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/jellyfin/jellyfin-vue"],
      versioning: "regex:^unstable\\.(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})\\.(?<build>[a-f0-9]+)$"
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/tensorchord/vchord-scratch"],
      versioning: "regex:^pg(?<compatibility>\\d+)-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/cloudnative-pg/postgis-extension"],
      versioning: "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<compatibility>\\d+-\\w+)$"
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["registry.kantai.xyz/**", "tif.etincelle.cloud/**"],
      enabled: false
    },
    // - Disable InfluxDB major releases; keep v1 and v2 separate
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["docker.io/library/influxdb", "influxdb"],
      matchUpdateTypes: ["major"],
      enabled: false,
    },
  ]
}
